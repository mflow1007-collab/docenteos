# Configuración Firebase — DocenteOS
# Copia este archivo como .env y completa los valores desde Firebase Console
# Firebase Console → Project Settings → Your apps → Config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
LIBRO_ABIERTO_USER=
LIBRO_ABIERTO_PASSWORD=

# ID del proyecto Firebase — requerido para verificar tokens en el AI Gateway
# Copiar desde Firebase Console → Project settings → General → Project ID
FIREBASE_PROJECT_ID=
