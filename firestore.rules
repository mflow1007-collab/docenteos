rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      // admin@docenteos.com es la cuenta administradora principal: acceso
      // completo por email EXACTO (la cuenta ya existe — nadie más puede
      // registrarla). Para el resto del dominio se exige correo verificado
      // (fix auditoría 2026-07-04: antes cualquier registro sin verificar
      // con un correo @docenteos.com obtenía admin total).
      // Escape hatch adicional: admins/{uid} vía Firebase Console (ID-20).
      return isAuth() && (
        request.auth.token.email == 'admin@docenteos.com'
        || (request.auth.token.email.matches('.*@docenteos\\.com')
          && request.auth.token.email_verified == true)
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Perfil de usuario + todas sus subcollections ─────────────────────────
    match /usuarios/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /cursos/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /instrumentos/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      // Hilo pedagógico (Fase 4): resultados de instrumento por estudiante.
      // Base de Mi Registro, avance por indicador, evidencias y reportes.
      // Campos mínimos exigidos al crear: cursoId, estudianteId, instrumentoId, estado.
      match /instrumentoResultados/{docId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin())
          && request.resource.data.keys().hasAll(['cursoId', 'estudianteId', 'instrumentoId', 'estado'])
          && request.resource.data.estado in ['evaluado', 'pendiente', 'no_entrego'];
      }
      match /preferencias/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /detalleEstudiantes/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /historialTemas/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /expedientesEstudiantes/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /evidenciasPedagogicas/{docId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        // Fase 11: el índice plano del banco exige el vínculo mínimo
        allow create: if (isOwner(userId) || isAdmin())
          && request.resource.data.keys().hasAll(['estudianteId', 'cursoId']);
      }

      // ID-01: subcollections del Registro (notas, aspectos, evidencias por estudiante)
      match /cursos/{cursoId}/registroAspectos/{aspId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        // Fase 11: campos mínimos del hilo pedagógico al crear un aspecto
        // string(): tolera IDs legacy numéricos (1 == "1" es false en reglas)
        allow create: if (isOwner(userId) || isAdmin())
          && request.resource.data.keys().hasAll(['cursoId', 'nombre'])
          && string(request.resource.data.cursoId) == cursoId;
      }
      match /cursos/{cursoId}/registroNotas/{notaId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        // Fase 11: una nota siempre pertenece a un estudiante y a un aspecto
        allow create: if (isOwner(userId) || isAdmin())
          && request.resource.data.keys().hasAll(['cursoId', 'estudianteId', 'aspectoId'])
          && string(request.resource.data.cursoId) == cursoId;
      }
      // Pase de lista (HITO 3.1): un doc por día con las marcas del curso
      match /cursos/{cursoId}/asistencia/{fecha} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      // Suspensiones de docencia (ADP, cooperativa, fenómeno atmosférico):
      // propiedad del DÍA del docente — cubre todos sus cursos
      match /suspensiones/{fecha} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      // Estudiantes del docente (usuarios/{uid}/estudiantes): estudiantesService
      // escribe aquí desde siempre — la regla faltaba en esta copia del repo
      match /estudiantes/{estId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      // Grupos académicos del docente (audit-cerebro F3)
      match /gruposAcademicos/{grupoId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /cursos/{cursoId}/estudiantes/{estId}/evidencias/{evId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        // Fase 11: toda evidencia queda vinculada a su estudiante y curso
        allow create: if (isOwner(userId) || isAdmin())
          && request.resource.data.keys().hasAll(['estudianteId', 'cursoId'])
          && string(request.resource.data.estudianteId) == estId
          && string(request.resource.data.cursoId) == cursoId;
      }

      match /paymentHistory/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // ── Planificaciones ──────────────────────────────────────────────────────
    // document contiene campo "usuario: uid"
    match /planificaciones/{docId} {
      allow read: if isAuth() && (
        resource == null || resource.data.usuario == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.usuario == request.auth.uid;
      allow update: if isAuth() && resource.data.usuario == request.auth.uid;
      allow delete: if isAuth() && resource.data.usuario == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // ── Registros de calificaciones ──────────────────────────────────────────
    // document ID: {uid}_{cursoId}
    match /registrosCalificaciones/{docId} {
      allow read, write: if isAuth() && docId.matches(request.auth.uid + '_.*');
      allow read, write: if isAdmin();
    }

    // ── Horarios de cursos ───────────────────────────────────────────────────
    // document ID: {uid}_{cursoId}
    match /horariosCursos/{docId} {
      allow read, write: if isAuth() && docId.matches(request.auth.uid + '_.*');
      allow read, write: if isAdmin();
    }

    // ── Historial de IA ──────────────────────────────────────────────────────
    // document contiene campo "usuario: uid"
    match /historialIA/{docId} {
      allow read: if isAuth() && resource.data.usuario == request.auth.uid;
      allow create: if isAuth() && request.resource.data.usuario == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.usuario == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // ── Auditoría ────────────────────────────────────────────────────────────
    match /auditoria/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    // ── Diseño Curricular MINERD ──────────────────────────────────────────────
    // ID-02: colección leída por curriculumService — sin regla causaba fallo silencioso
    match /diseñoCurricular/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Centros educativos (multi-centro) ─────────────────────────────────────
    // Lectura: cualquier docente autenticado (para pre-cargar info de su centro)
    // Escritura: docentes pueden crear su propio centro al completar perfil
    // ID-15: update restringido a isAdmin() para evitar que docentes editen centros ajenos
    match /centros/{centroId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Logs de uso de IA ────────────────────────────────────────────────────
    // uid: campo real guardado por usage.js (era userId — bug corregido aquí)
    match /aiLogs/{docId} {
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ── Pagos ────────────────────────────────────────────────────────────────
    match /payments/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }
    match /paymentReports/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Configuración del sistema ─────────────────────────────────────────────
    // config/ia-gateway es leído por todos los usuarios para el gateway de IA
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Banco Inteligente de Conocimiento (BIC) ───────────────────────────────
    // Lectura: todos los usuarios autenticados (sugerencias de planificación)
    // Escritura de nuevos docs: usuarios autenticados (indexar sus planificaciones)
    // Actualización/eliminación: solo admin (para curar el banco)
    match /bic_planes/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /bic_versiones/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /bic_actividades/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /bic_instrumentos/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /bic_auditorias/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Knowledge Engine ──────────────────────────────────────────────────────
    match /ke_topics/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    // Los estilos los crean los docentes al entrenar su IA
    match /ke_estilos/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /ke_ejemplos/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    // Agentes y sus subcollections de memoria
    match /ke_agentes/{agentId} {
      allow read: if isAuth();
      allow write: if isAdmin();

      match /ke_memoria/{memId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }
      match /ke_versiones/{verId} {
        allow read, write: if isAdmin();
      }
    }

    // ── Learning Engine ────────────────────────────────────────────────────────
    // le_eventos: docentes escriben sus propios eventos; solo admin puede leer
    match /le_eventos/{docId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
    // le_insights: solo admin (generados automáticamente, revisados por admin)
    match /le_insights/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Banco de Conocimiento ────────────────────────────────────────────────
    // Lectura para autenticados: los guards de resolución de malla
    // (getActiveMallaSourceGuards) corren en el flujo del DOCENTE al generar
    // y en el Asesor Pedagógico. Son metadatos de fuentes oficiales, no datos
    // sensibles. Escritura solo admin.
    match /knowledgeSources/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    // Contenido curricular estructurado — docentes leen para generar planificaciones
    match /curricularContent/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    // ── Banco de Aprendizaje (secuencias cosechadas) ─────────────────────────
    // Cosecha OPT-IN: el docente crea SOLO en estado 'cosechada' y con su
    // propio uid en la procedencia. Validar/retirar/servir es del admin.
    // El gate de servicio (config/banco-aprendizaje) nace apagado.
    match /bancoAprendizaje/{docId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.estado == 'cosechada'
        && request.resource.data.procedencia.docenteUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Fuentes oficiales MINERD ───────────────────────────────────────────────
    match /fuentesOficiales/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /fuentesCambios/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Materiales educativos ─────────────────────────────────────────────────
    match /materiales/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Barrido audit-cerebro F3 (2026-07-17): 7 colecciones más destapadas
    //    por el auditor automatizado en su primera corrida ───────────────────

    // Banco Pedagógico (bp_*): lectura docentes; publicación curada por admin
    match /bp_temas/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /bp_actividades/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /bp_instrumentos/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /bp_recursos/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /bp_neae/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Configuración global del panel admin (seguridad, firebase, general)
    match /configuracionGlobal/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Barrido auditoría HITO 5 (2026-07-16): colecciones que el código usa
    //    y caían en el deny por defecto (fallo silencioso) ────────────────────

    // Sesiones de aula guardadas al finalizar clase (campo usuario: uid)
    match /sesiones-aula/{docId} {
      allow create: if isAuth() && request.resource.data.usuario == request.auth.uid;
      allow read, update, delete: if isAuth() && resource.data.usuario == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // Caché compartido de respuestas IA (claves por contenido, sin datos personales)
    match /aiCache/{docId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // Asistente personal: conversaciones, uso y memoria POR USUARIO
    match /chat_personal/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /chat_memoria/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Catálogo de currículos (páginas admin) y fuentes aprobadas del monitor
    match /curriculos/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /fuentesAprobadas/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Trabajos de Potente IA (solo panel admin)
    match /admin_potente_ia_trabajos/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Banco IA (Prompts) ────────────────────────────────────────────────────
    // Catálogo de prompts administrado desde el sidebar admin. Sin esta regla
    // caía en el deny por defecto y el módulo fallaba en silencio.
    match /promptsIA/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Whitelist de admins (ID-20) ───────────────────────────────────────────
    // Los UIDs de administradores se agregan manualmente desde Firebase Console.
    // Para activar la whitelist, cambiar isAdmin() a verificar existence aquí.
    match /admins/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if isAdmin();
    }
  }
}
